#####################################################
##                                                 ##
##  Keyfile for TIP3P-FB Rigid 3-Site Water Model  ##
##                                                 ##
#####################################################

parameters              NONE
rattle                  WATER

vdwtype                 LENNARD-JONES
radiusrule              ARITHMETIC
radiustype              R-MIN
radiussize              DIAMETER
epsilonrule             GEOMETRIC
dielectric              1.0000

## TIP3P-FB Parameters (J Phys Chem Lett, 5, 1885-1891, 2014)

atom             1    O     "TIP3P-FB Water O"     8     15.995     2
atom             2    H     "TIP3P-FB Water H"     1      1.008     1

bond             1    2           1000.00       1.0118
angle            2    1    2       100.00       108.15

vdw              1              3.5671844    0.1558652
vdw              2                  0.000       0.0000

charge           1               -0.84844
charge           2                0.42422
