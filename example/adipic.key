parameters       ../params/oplsaa08
#verbose

ewald
ewald-cutoff     9.0
vdw-cutoff       9.0
vdw-correction
neighbor-list
list-buffer      0.5
freeze

thermostat       BUSSI
barostat         BUSSI
pressure         ANISO

# X-ray unit cell at 100K; Acta Cryst, E65, o624 (2009)

#spacegroup      P1(-)
#x-axis          6.7666
#y-axis          6.9992
#z-axis          7.7180
#alpha           93.794
#beta           104.321
#gamma          102.689
